{% doc %}
  @prompt
    A product card that includes the product image at the top, then the title below. mak eit like a carousel goig over the different colors  of the product, the colors are: Maroc, Algérie, Tunisie, Congo, Sénégal, Côte D'ivoir, every carousel imiage should be another color
{% enddoc %}

{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-card-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
  }

  @media screen and (min-width: 750px) {
    .ai-product-card-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
    }
  }

  .ai-product-card-container-{{ ai_gen_id }} {
    background-color: {{ block.settings.card_background }};
    border-radius: {{ block.settings.border_radius }}px;
    overflow: hidden;
    box-shadow: 0 {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
  }

  .ai-product-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    aspect-ratio: {{ block.settings.image_ratio }};
    overflow: hidden;
    background-color: #f5f5f5;
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0;
    transition: opacity 0.4s ease;
  }

  .ai-product-card-image-{{ ai_gen_id }}.active {
    opacity: 1;
  }

  .ai-product-card-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: #f4f4f4;
  }

  .ai-product-card-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.3;
  }

  .ai-product-card-dots-{{ ai_gen_id }} {
    position: absolute;
    bottom: 12px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    gap: 8px;
    z-index: 2;
  }

  .ai-product-card-dot-{{ ai_gen_id }} {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background-color: rgba(255, 255, 255, 0.5);
    border: none;
    padding: 0;
    cursor: pointer;
    transition: all 0.3s ease;
  }

  .ai-product-card-dot-{{ ai_gen_id }}.active {
    background-color: {{ block.settings.dot_active_color }};
    transform: scale(1.3);
  }

  .ai-product-card-info-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    text-align: {{ block.settings.text_alignment }};
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 8px 0;
    line-height: 1.3;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    color: {{ block.settings.price_color }};
    font-weight: 600;
  }

  .ai-product-card-link-{{ ai_gen_id }} {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .ai-product-card-empty-{{ ai_gen_id }} {
    padding: 20px;
    text-align: center;
    color: #999;
    font-size: 14px;
  }
{% endstyle %}

<product-card-carousel-{{ ai_gen_id }} class="ai-product-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.product != blank %}
    <a href="{{ block.settings.product.url }}" class="ai-product-card-link-{{ ai_gen_id }}">
      <div class="ai-product-card-container-{{ ai_gen_id }}">
        <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
          {% assign color_option = null %}
          {% assign target_colors = 'maroc,algérie,tunisie,congo,sénégal,côte d' | split: ',' %}
          
          {% for option in block.settings.product.options_with_values %}
            {% assign option_name_downcase = option.name | downcase %}
            {% if option_name_downcase contains 'color' or option_name_downcase contains 'colour' or option_name_downcase contains 'pays' or option_name_downcase contains 'country' %}
              {% assign color_option = option %}
              {% break %}
            {% endif %}
          {% endfor %}

          {% if color_option != null and color_option.values.size > 0 %}
            {% assign displayed_colors = '' %}
            {% assign image_count = 0 %}
            
            {% for target_color in target_colors %}
              {% assign found_variant = false %}
              
              {% for variant in block.settings.product.variants %}
                {% if found_variant %}
                  {% break %}
                {% endif %}
                
                {% if variant.featured_image %}
                  {% for option in variant.options %}
                    {% assign option_downcase = option | downcase %}
                    {% if option_downcase contains target_color %}
                      {% assign already_displayed = false %}
                      {% assign displayed_array = displayed_colors | split: ',' %}
                      {% for displayed in displayed_array %}
                        {% if displayed == option %}
                          {% assign already_displayed = true %}
                          {% break %}
                        {% endif %}
                      {% endfor %}
                      
                      {% if already_displayed == false %}
                        <img
                          src="{{ variant.featured_image | image_url: width: 800 }}"
                          alt="{{ block.settings.product.title | escape }} - {{ option | escape }}"
                          loading="lazy"
                          width="800"
                          height="800"
                          class="ai-product-card-image-{{ ai_gen_id }} {% if image_count == 0 %}active{% endif %}"
                          data-color-index="{{ image_count }}"
                        >
                        
                        {% if displayed_colors == '' %}
                          {% assign displayed_colors = option %}
                        {% else %}
                          {% assign displayed_colors = displayed_colors | append: ',' | append: option %}
                        {% endif %}
                        
                        {% assign image_count = image_count | plus: 1 %}
                        {% assign found_variant = true %}
                        {% break %}
                      {% endif %}
                    {% endif %}
                  {% endfor %}
                {% endif %}
              {% endfor %}
            {% endfor %}

            {% if image_count > 0 %}
              <div class="ai-product-card-dots-{{ ai_gen_id }}">
                {% for i in (1..image_count) %}
                  <button
                    class="ai-product-card-dot-{{ ai_gen_id }} {% if forloop.first %}active{% endif %}"
                    data-index="{{ forloop.index0 }}"
                    aria-label="View color {{ forloop.index }}"
                  ></button>
                {% endfor %}
              </div>
            {% else %}
              {% if block.settings.product.featured_image %}
                <img
                  src="{{ block.settings.product.featured_image | image_url: width: 800 }}"
                  alt="{{ block.settings.product.title | escape }}"
                  loading="lazy"
                  width="800"
                  height="800"
                  class="ai-product-card-image-{{ ai_gen_id }} active"
                >
              {% else %}
                <div class="ai-product-card-placeholder-{{ ai_gen_id }}">
                  {{ 'product-1' | placeholder_svg_tag }}
                </div>
              {% endif %}
            {% endif %}
          {% else %}
            {% if block.settings.product.featured_image %}
              <img
                src="{{ block.settings.product.featured_image | image_url: width: 800 }}"
                alt="{{ block.settings.product.title | escape }}"
                loading="lazy"
                width="800"
                height="800"
                class="ai-product-card-image-{{ ai_gen_id }} active"
              >
            {% else %}
              <div class="ai-product-card-placeholder-{{ ai_gen_id }}">
                {{ 'product-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          {% endif %}
        </div>

        <div class="ai-product-card-info-{{ ai_gen_id }}">
          <h3 class="ai-product-card-title-{{ ai_gen_id }}">{{ block.settings.product.title }}</h3>
          <div class="ai-product-card-price-{{ ai_gen_id }}">
            {{ block.settings.product.price | money }}
          </div>
        </div>
      </div>
    </a>
  {% else %}
    <div class="ai-product-card-container-{{ ai_gen_id }}">
      <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
        <div class="ai-product-card-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      </div>
      <div class="ai-product-card-empty-{{ ai_gen_id }}">
        Select a product to display
      </div>
    </div>
  {% endif %}
</product-card-carousel-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCardCarousel{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
        this.currentIndex = 0;
        this.autoplayInterval = null;
      }

      connectedCallback() {
        this.images = this.querySelectorAll('.ai-product-card-image-{{ ai_gen_id }}');
        this.dots = this.querySelectorAll('.ai-product-card-dot-{{ ai_gen_id }}');

        if (this.images.length <= 1) return;

        this.dots.forEach((dot, index) => {
          dot.addEventListener('click', (e) => {
            e.preventDefault();
            this.goToSlide(index);
          });
        });

        if ({{ block.settings.enable_autoplay | json }}) {
          this.startAutoplay();

          this.addEventListener('mouseenter', () => this.stopAutoplay());
          this.addEventListener('mouseleave', () => this.startAutoplay());
        }
      }

      goToSlide(index) {
        this.images.forEach((img, i) => {
          img.classList.toggle('active', i === index);
        });

        this.dots.forEach((dot, i) => {
          dot.classList.toggle('active', i === index);
        });

        this.currentIndex = index;
      }

      startAutoplay() {
        this.stopAutoplay();
        this.autoplayInterval = setInterval(() => {
          const nextIndex = (this.currentIndex + 1) % this.images.length;
          this.goToSlide(nextIndex);
        }, {{ block.settings.autoplay_speed }} * 1000);
      }

      stopAutoplay() {
        if (this.autoplayInterval) {
          clearInterval(this.autoplayInterval);
          this.autoplayInterval = null;
        }
      }

      disconnectedCallback() {
        this.stopAutoplay();
      }
    }

    customElements.define('product-card-carousel-{{ ai_gen_id }}', ProductCardCarousel{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Product color carousel",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Product"
    },
    {
      "type": "product",
      "id": "product",
      "label": "Product"
    },
    {
      "type": "paragraph",
      "content": "Each carousel image will show a different color: Maroc, Algérie, Tunisie, Congo, Sénégal, Côte D'ivoire"
    },
    {
      "type": "header",
      "content": "Carousel"
    },
    {
      "type": "checkbox",
      "id": "enable_autoplay",
      "label": "Enable autoplay",
      "default": true
    },
    {
      "type": "range",
      "id": "autoplay_speed",
      "min": 2,
      "max": 10,
      "step": 1,
      "unit": "s",
      "label": "Autoplay speed",
      "default": 3
    },
    {
      "type": "select",
      "id": "image_ratio",
      "label": "Image ratio",
      "options": [
        {
          "value": "1/1",
          "label": "Square (1:1)"
        },
        {
          "value": "4/5",
          "label": "Portrait (4:5)"
        },
        {
          "value": "3/4",
          "label": "Portrait (3:4)"
        },
        {
          "value": "16/9",
          "label": "Landscape (16:9)"
        }
      ],
      "default": "4/5"
    },
    {
      "type": "color",
      "id": "dot_active_color",
      "label": "Active dot color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Card style"
    },
    {
      "type": "color",
      "id": "card_background",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "border_radius",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "label": "Border radius",
      "default": 12
    },
    {
      "type": "range",
      "id": "shadow_opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "label": "Shadow opacity",
      "default": 10
    },
    {
      "type": "range",
      "id": "shadow_vertical",
      "min": 0,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Shadow vertical offset",
      "default": 6
    },
    {
      "type": "range",
      "id": "shadow_blur",
      "min": 0,
      "max": 40,
      "step": 5,
      "unit": "px",
      "label": "Shadow blur",
      "default": 15
    },
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "range",
      "id": "content_padding",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "label": "Content padding",
      "default": 16
    },
    {
      "type": "select",
      "id": "text_alignment",
      "label": "Text alignment",
      "options": [
        {
          "value": "left",
          "label": "Left"
        },
        {
          "value": "center",
          "label": "Center"
        },
        {
          "value": "right",
          "label": "Right"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "title_size",
      "min": 12,
      "max": 32,
      "step": 2,
      "unit": "px",
      "label": "Title size",
      "default": 16
    },
    {
      "type": "range",
      "id": "title_weight",
      "min": 400,
      "max": 700,
      "step": 100,
      "label": "Title weight",
      "default": 600
    },
    {
      "type": "color",
      "id": "title_color",
      "label": "Title color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "price_size",
      "min": 12,
      "max": 28,
      "step": 2,
      "unit": "px",
      "label": "Price size",
      "default": 14
    },
    {
      "type": "color",
      "id": "price_color",
      "label": "Price color",
      "default": "#121212"
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Desktop width",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    }
  ],
  "presets": [
    {
      "name": "Product color carousel"
    }
  ]
}
{% endschema %}
