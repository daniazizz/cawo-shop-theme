{% doc %}
  @prompt
    A product card that includes the product image at the top, then the price and title below. Add a smooth holographic shimmer effect and a shadow.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-card-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    max-width: 100%;
    position: relative;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px;
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical }}px {{ block.settings.shadow_blur }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 }});
    background-color: {{ block.settings.card_background }};
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  @media screen and (min-width: 750px) {
    .ai-product-card-{{ ai_gen_id }} {
      width: {{ block.settings.desktop_width_percent }}%;
    }
  }

  .ai-product-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    box-shadow: {{ block.settings.shadow_horizontal }}px {{ block.settings.shadow_vertical | plus: 4 }}px {{ block.settings.shadow_blur | plus: 5 }}px rgba(0, 0, 0, {{ block.settings.shadow_opacity | divided_by: 100.0 | times: 1.2 }});
  }

  .ai-product-card-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: -50%;
    left: -50%;
    width: 200%;
    height: 200%;
    background: linear-gradient(
      45deg,
      transparent 30%,
      rgba(255, 255, 255, 0.1) 40%,
      rgba(255, 255, 255, 0.3) 50%,
      rgba(255, 255, 255, 0.1) 60%,
      transparent 70%
    );
    background-size: 200% 200%;
    animation: ai-holographic-shimmer-{{ ai_gen_id }} {{ block.settings.shimmer_duration }}s ease-in-out infinite;
    pointer-events: none;
    z-index: 1;
  }

  @keyframes ai-holographic-shimmer-{{ ai_gen_id }} {
    0% {
      background-position: 200% 200%;
    }
    100% {
      background-position: -200% -200%;
    }
  }

  .ai-product-card-image-wrapper-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    overflow: hidden;
    border-radius: {{ block.settings.border_radius }}px {{ block.settings.border_radius }}px 0 0;
  }

  .ai-product-card-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
    aspect-ratio: {{ block.settings.image_ratio }};
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    aspect-ratio: {{ block.settings.image_ratio }};
    background-color: #f4f4f4;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-product-card-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 200px;
    max-height: 200px;
  }

  .ai-product-card-content-{{ ai_gen_id }} {
    padding: {{ block.settings.content_padding }}px;
    position: relative;
    z-index: 2;
  }

  .ai-product-card-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0 0 {{ block.settings.spacing_between }}px 0;
    line-height: 1.3;
  }

  .ai-product-card-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.price_size }}px;
    font-weight: {{ block.settings.price_weight }};
    color: {{ block.settings.price_color }};
    margin: 0;
  }

  .ai-product-card-price-compare-{{ ai_gen_id }} {
    text-decoration: line-through;
    opacity: 0.6;
    margin-right: 8px;
  }

  .ai-product-card-link-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    z-index: 3;
    text-indent: -9999px;
  }
{% endstyle %}

<product-card-{{ ai_gen_id }} class="ai-product-card-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.product %}
    <a href="{{ block.settings.product.url }}" class="ai-product-card-link-{{ ai_gen_id }}">
      {{ block.settings.product.title }}
    </a>

    <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
      {% if block.settings.product.featured_image %}
        <img
          src="{{ block.settings.product.featured_image | image_url: width: 800 }}"
          alt="{{ block.settings.product.featured_image.alt | escape }}"
          class="ai-product-card-image-{{ ai_gen_id }}"
          loading="lazy"
          width="{{ block.settings.product.featured_image.width }}"
          height="{{ block.settings.product.featured_image.height }}"
        >
      {% else %}
        <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-product-card-content-{{ ai_gen_id }}">
      <div class="ai-product-card-price-{{ ai_gen_id }}">
        {% if block.settings.product.compare_at_price > block.settings.product.price %}
          <span class="ai-product-card-price-compare-{{ ai_gen_id }}">
            {{ block.settings.product.compare_at_price | money }}
          </span>
        {% endif %}
        <span>{{ block.settings.product.price | money }}</span>
      </div>

      <h3 class="ai-product-card-title-{{ ai_gen_id }}">
        {{ block.settings.product.title }}
      </h3>
    </div>
  {% else %}
    <div class="ai-product-card-image-wrapper-{{ ai_gen_id }}">
      <div class="ai-product-card-image-placeholder-{{ ai_gen_id }}">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    </div>

    <div class="ai-product-card-content-{{ ai_gen_id }}">
      <div class="ai-product-card-price-{{ ai_gen_id }}">
        €29.99
      </div>

      <h3 class="ai-product-card-title-{{ ai_gen_id }}">
        Product title
      </h3>
    </div>
  {% endif %}
</product-card-{{ ai_gen_id }}>

<script>
  (function() {
    class ProductCard{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
      }
    }

    customElements.define('product-card-{{ ai_gen_id }}', ProductCard{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
