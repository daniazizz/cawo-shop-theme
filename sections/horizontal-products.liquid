{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .color-scheme-{{ section.id }}.color-custom {
    --color-background: {{ section.settings.custom_colors_background.red }}, {{ section.settings.custom_colors_background.green }}, {{ section.settings.custom_colors_background.blue }};
    --gradient-background: {% if section.settings.custom_gradient_background != blank %}{{ section.settings.custom_gradient_background }}{% else %}{{ section.settings.custom_colors_background }}{% endif %};
    --color-foreground: {{ section.settings.custom_colors_text.red }}, {{ section.settings.custom_colors_text.green }}, {{ section.settings.custom_colors_text.blue }};
  }

  .horizontal-products-{{ section.id }} {
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    gap: 0.6rem;
    padding: 0 0.5rem 0.3rem;
    scroll-behavior: smooth;
    scrollbar-width: none;
    -ms-overflow-style: none;
  }

  .horizontal-products-{{ section.id }}::-webkit-scrollbar {
    display: none;
  }

  .horizontal-products-{{ section.id }} .product-card {
    flex: 0 0 {{ section.settings.card_size }}px;
    min-width: {{ section.settings.card_size }}px;
  }

  @media (max-width: 640px) {
    .horizontal-products-{{ section.id }} .product-card {
      flex: 0 0 {{ section.settings.card_size | times: 0.85 | round: 0 }}px;
      min-width: {{ section.settings.card_size | times: 0.85 | round: 0 }}px;
    }
  }

  @media (max-width: 480px) {
    .horizontal-products-{{ section.id }} .product-card {
      flex: 0 0 {{ section.settings.card_size | times: 0.7 | round: 0 }}px;
      min-width: {{ section.settings.card_size | times: 0.7 | round: 0 }}px;
    }
  }

  .product-card {
    overflow: hidden;
    cursor: pointer;
  }

  .product-card a {
    text-decoration: none;
    color: inherit;
    display: block;
  }

  .product-card__image {
    position: relative;
    overflow: hidden;
    background: #f5f5f5;
    aspect-ratio: 3 / 4;
    border-radius: 6px;
  }

  .product-card__image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.35s ease, opacity 0.3s ease;
  }

  .product-card:hover .product-card__image img {
    transform: scale(1.05);
    opacity: 0.92;
  }

  .product-card__content {
    padding: 0.35rem 0.1rem 0;
  }

  .product-card__title {
    font-size: 11px;
    font-weight: 500;
    margin: 0;
    line-height: 1.25;
    letter-spacing: 0.01em;
    color: var(--color-foreground, #1a1a1a);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
  }

  .product-card__title a {
    color: inherit;
  }

  .title-wrapper-{{ section.id }} {
    margin-bottom: 0.6rem;
  }

  .title-wrapper-{{ section.id }} .section-heading {
    font-family: 'Bebas Neue', Impact, 'Arial Black', sans-serif;
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.06em;
    font-size: 15px;
    line-height: 1.1;
    margin: 0;
    text-align: left;
    color: var(--color-foreground, #111);
  }

  .title-wrapper-{{ section.id }} .section-heading.h1 {
    font-size: 22px;
  }

  .title-wrapper-{{ section.id }} .section-heading.h2 {
    font-size: 17px;
  }

  .title-wrapper-{{ section.id }} .section-heading.h3 {
    font-size: 13px;
  }

  {% unless section.settings.show_on_desktop %}
    @media screen and (min-width: 750px) {
      .horizontal-section-{{ section.id }} {
        display: none !important;
      }
    }
  {% endunless %}
{%- endstyle -%}

<div class="horizontal-section-{{ section.id }} color-scheme-{{ section.id }} color-{{ section.settings.color_scheme }} isolate gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {%- assign page_product = product -%}
    {% if section.settings.title != blank %}
      <div class="title-wrapper-{{ section.id }}">
        <h2 class="section-heading {{ section.settings.heading_size }}">
          {{ section.settings.title }}
        </h2>
      </div>
    {% endif %}

    <div class="horizontal-products-{{ section.id }}">
      {%- if section.settings.collection != blank -%}
        {%- assign shown = 0 -%}
        {%- for product in section.settings.collection.products -%}
          {%- if product.handle == page_product.handle -%}{%- continue -%}{%- endif -%}
          {%- if shown >= section.settings.products_to_show -%}{%- break -%}{%- endif -%}
          {%- assign shown = shown | plus: 1 -%}
          <div class="product-card">
            <a href="{{ product.url }}">
              {% if product.featured_image %}
                <div class="product-card__image">
                  <img
                    src="{{ product.featured_image | image_url: width: 300, height: 400 }}"
                    alt="{{ product.featured_image.alt | escape }}"
                    loading="lazy"
                  >
                </div>
              {% endif %}
              {% if section.settings.show_title %}
                <div class="product-card__content">
                  <h3 class="product-card__title">{{ product.title }}</h3>
                </div>
              {% endif %}
            </a>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..8) -%}
          <div class="product-card placeholder-product">
            <div class="product-card__image" style="background: #eee;"></div>
            <div class="product-card__content">
              <div style="height: 10px; background: #ddd; border-radius: 4px; width: 75%;"></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Horizontal Products",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "checkbox",
      "id": "show_on_desktop",
      "default": true,
      "label": "Show on desktop"
    },
    {
      "type": "checkbox",
      "id": "show_title",
      "default": true,
      "label": "Show product title"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Featured Products",
      "label": "Section heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h3",
          "label": "Small"
        },
        {
          "value": "h2",
          "label": "Medium"
        },
        {
          "value": "h1",
          "label": "Large"
        }
      ],
      "default": "h2",
      "label": "Heading size"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 50,
      "step": 1,
      "default": 16,
      "label": "Products to show"
    },
    {
      "type": "range",
      "id": "card_size",
      "min": 80,
      "max": 250,
      "step": 10,
      "default": 130,
      "unit": "px",
      "label": "Card size"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "Accent 1"
        },
        {
          "value": "accent-2",
          "label": "Accent 2"
        },
        {
          "value": "background-1",
          "label": "Background 1"
        },
        {
          "value": "background-2",
          "label": "Background 2"
        },
        {
          "value": "inverse",
          "label": "Inverse"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "background-1",
      "label": "Color scheme"
    },
    {
      "type": "color",
      "id": "custom_colors_background",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_colors_text",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 16
    }
  ],
  "presets": [
    {
      "name": "Horizontal Products"
    }
  ]
}
{% endschema %}
