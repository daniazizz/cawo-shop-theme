{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }

  .color-scheme-{{ section.id }}.color-custom {
    --color-background: {{ section.settings.custom_colors_background.red }}, {{ section.settings.custom_colors_background.green }}, {{ section.settings.custom_colors_background.blue }};
    --gradient-background: {% if section.settings.custom_gradient_background != blank %}{{ section.settings.custom_gradient_background }}{% else %}{{ section.settings.custom_colors_background }}{% endif %};
    --color-foreground: {{ section.settings.custom_colors_text.red }}, {{ section.settings.custom_colors_text.green }}, {{ section.settings.custom_colors_text.blue }};
  }

  .horizontal-products-{{ section.id }} {
    display: flex;
    overflow-x: auto;
    overflow-y: hidden;
    gap: 0.5rem;
    padding: 0 0.75rem 0;
    scroll-behavior: smooth;
    scrollbar-width: thin;
    scrollbar-color: rgba(0, 0, 0, 0.1) transparent;
  }

  .horizontal-products-{{ section.id }}::-webkit-scrollbar {
    height: 3px;
  }

  .horizontal-products-{{ section.id }}::-webkit-scrollbar-track {
    background: transparent;
  }

  .horizontal-products-{{ section.id }}::-webkit-scrollbar-thumb {
    background-color: rgba(0, 0, 0, 0.1);
    border-radius: 2px;
  }

  .horizontal-products-{{ section.id }} .product-card {
    flex: 0 0 19%;
    min-width: 140px;
  }

  @media (max-width: 640px) {
    .horizontal-products-{{ section.id }} .product-card {
      flex: 0 0 28%;
      min-width: 100px;
    }
  }

  @media (max-width: 480px) {
    .horizontal-products-{{ section.id }} .product-card {
      flex: 0 0 40%;
      min-width: 85px;
    }
  }

  .product-card {
    background: var(--color-background, #fff);
    border-radius: 4px;
    overflow: hidden;
    transition: transform 0.2s ease;
    border: 1px solid #e8e8e8;
  }

  .product-card:hover {
    transform: translateY(-1px);
  }

  .product-card__image {
    position: relative;
    overflow: hidden;
    background: #f8f8f8;
    aspect-ratio: 1;
  }

  .product-card__image img {
    display: block;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.2s ease;
  }

  .product-card:hover .product-card__image img {
    transform: scale(1.02);
  }

  .product-card__badge {
    position: absolute;
    top: 4px;
    left: 4px;
    background: {{ section.settings.badge_color }};
    color: white;
    padding: 2px 4px;
    border-radius: 2px;
    font-size: 9px;
    font-weight: bold;
    z-index: 2;
    line-height: 1;
  }

  .product-card__content {
    padding: 6px;
  }

  .product-card__title {
    font-size: 11px;
    font-weight: 500;
    margin: 0 0 3px;
    line-height: 1.2;
    color: var(--color-foreground, #000);
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    min-height: 20px;
  }

  .product-card__rating {
    display: flex;
    align-items: center;
    gap: 2px;
    margin-bottom: 3px;
    font-size: 10px;
  }

  .product-card__stars {
    color: #ffc107;
    letter-spacing: -1px;
    font-size: 9px;
  }

  .product-card__price {
    font-size: 11px;
    font-weight: 600;
    color: var(--color-foreground, #000);
  }

  .product-card__price del {
    opacity: 0.5;
    text-decoration: line-through;
    margin-right: 3px;
    font-size: 9px;
  }

  .title-wrapper {
    margin-bottom: 0.8rem;
  }
{%- endstyle -%}

<div class="color-scheme-{{ section.id }} color-{{ section.settings.color_scheme }} isolate gradient section-{{ section.id }}-padding">
  <div class="page-width">
    {% if section.settings.title != blank %}
      <div class="title-wrapper">
        <h2 class="title {{ section.settings.heading_size }}" style="margin-bottom: 1rem; margin-top: 0;">
          {{ section.settings.title }}
        </h2>
      </div>
    {% endif %}

    <div class="horizontal-products-{{ section.id }}">
      {%- if section.settings.collection != blank -%}
        {%- for product in section.settings.collection.products limit: section.settings.products_to_show -%}
          <div class="product-card">
            {% if product.featured_image %}
              <div class="product-card__image">
                <img
                  src="{{ product.featured_image | image_url: width: 300, height: 300 }}"
                  alt="{{ product.featured_image.alt | escape }}"
                  loading="lazy"
                >
                {% if forloop.index == 1 and section.settings.show_bestseller_badge %}
                  <div class="product-card__badge">#{{ forloop.index }} Best Seller</div>
                {% elsif forloop.index <= 4 and section.settings.show_badge_numbers %}
                  <div class="product-card__badge">#{{ forloop.index }}</div>
                {% endif %}
              </div>
            {% endif %}
            <div class="product-card__content">
              <h3 class="product-card__title">
                <a href="{{ product.url }}">{{ product.title }}</a>
              </h3>

              {% if section.settings.show_rating and product.metafields.reviews.rating %}
                <div class="product-card__rating">
                  <span class="product-card__stars">
                    {%- for i in (1..5) -%}
                      {% if i <= product.metafields.reviews.rating %}★{% else %}☆{% endif %}
                    {%- endfor -%}
                  </span>
                  <span>({{ product.metafields.reviews.rating_count | default: 0 }})</span>
                </div>
              {% endif %}

              <div class="product-card__price">
                {%- if product.compare_at_price -%}
                  <del>{{ product.compare_at_price | money }}</del>
                {%- endif -%}
                {{ product.price | money }}
              </div>
            </div>
          </div>
        {%- endfor -%}
      {%- else -%}
        {%- for i in (1..8) -%}
          <div class="product-card placeholder-product">
            <div class="product-card__image" style="background: #f0f0f0;"></div>
            <div class="product-card__content">
              <div style="height: 8px; background: #e0e0e0; border-radius: 2px; margin-bottom: 3px;"></div>
              <div style="height: 8px; background: #e0e0e0; border-radius: 2px; width: 60%; margin-bottom: 3px;"></div>
              <div style="height: 8px; background: #e0e0e0; border-radius: 2px; width: 50%;"></div>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Horizontal Products",
  "tag": "section",
  "class": "section",
  "disabled_on": {
    "groups": ["header", "footer"]
  },
  "settings": [
    {
      "type": "header",
      "content": "Display"
    },
    {
      "type": "text",
      "id": "title",
      "default": "Featured Products",
      "label": "Section heading"
    },
    {
      "type": "select",
      "id": "heading_size",
      "options": [
        {
          "value": "h3",
          "label": "Small"
        },
        {
          "value": "h2",
          "label": "Medium"
        },
        {
          "value": "h1",
          "label": "Large"
        }
      ],
      "default": "h2",
      "label": "Heading size"
    },
    {
      "type": "collection",
      "id": "collection",
      "label": "Collection"
    },
    {
      "type": "range",
      "id": "products_to_show",
      "min": 2,
      "max": 50,
      "step": 1,
      "default": 16,
      "label": "Products to show"
    },
    {
      "type": "checkbox",
      "id": "show_badge_numbers",
      "default": true,
      "label": "Show badge numbers (#1, #2, etc)"
    },
    {
      "type": "checkbox",
      "id": "show_bestseller_badge",
      "default": true,
      "label": "Show 'Best Seller' for first product"
    },
    {
      "type": "checkbox",
      "id": "show_rating",
      "default": true,
      "label": "Show product ratings"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "select",
      "id": "color_scheme",
      "options": [
        {
          "value": "accent-1",
          "label": "Accent 1"
        },
        {
          "value": "accent-2",
          "label": "Accent 2"
        },
        {
          "value": "background-1",
          "label": "Background 1"
        },
        {
          "value": "background-2",
          "label": "Background 2"
        },
        {
          "value": "inverse",
          "label": "Inverse"
        },
        {
          "value": "custom",
          "label": "Custom"
        }
      ],
      "default": "background-1",
      "label": "Color scheme"
    },
    {
      "type": "color",
      "id": "badge_color",
      "label": "Badge color",
      "default": "#dd1d1d"
    },
    {
      "type": "color",
      "id": "custom_colors_background",
      "label": "Background color",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "custom_colors_text",
      "label": "Text color",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Spacing"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 16
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 16
    }
  ]
}
{% endschema %}
