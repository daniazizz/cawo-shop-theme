        "custom_liquid": "<style>\n  .rr_countdown_wrapper {\n    background-color: #000000;\n    padding-top: 12px;\n    padding-bottom: 12px;\n    width: 100%;\n    overflow: hidden;\n    position: relative;\n  }\n  .rr_countdown_container {\n    max-width: 1200px;\n    margin: 0 auto;\n    padding: 0 10px;\n    display: flex;\n    flex-direction: row;\n    align-items: center;\n    justify-content: center;\n    gap: 10px;\n    text-align: center;\n  }\n  .rr_countdown_text_content {\n    min-width: 0;\n  }\n  .rr_countdown_text_content h2 {\n    color: #ffffff;\n    margin: 0;\n    line-height: 1.1;\n    font-size: 15px;\n    font-weight: 700;\n    letter-spacing: 0.5px;\n  }\n  .rr_countdown_text_content p {\n    color: #ffffff;\n    margin: 2px 0 0 0;\n    font-size: 10px;\n    opacity: 0.9;\n    line-height: 1.2;\n  }\n  .rr_countdown_timer_box {\n    display: flex;\n    align-items: flex-start;\n    gap: 4px;\n    flex-shrink: 0;\n    visibility: hidden;\n    opacity: 0;\n    transition: opacity 0.3s ease;\n  }\n  .rr_countdown_timer_box.rr_timer_loaded {\n    visibility: visible;\n    opacity: 1;\n  }\n  .rr_timer_block {\n    display: flex;\n    flex-direction: column;\n    align-items: center;\n    min-width: 28px;\n  }\n  .rr_time_digit {\n    font-size: 16px;\n    line-height: 1;\n    font-weight: 600;\n    color: #ffffff;\n    font-family: monospace, sans-serif;\n  }\n  .rr_time_label {\n    font-size: 8px;\n    text-transform: capitalize;\n    margin-top: 1px;\n    color: #ffffff;\n    opacity: 0.8;\n  }\n  .rr_timer_separator {\n    font-size: 16px;\n    line-height: 1;\n    color: #ffffff;\n    font-weight: 600;\n    margin-top: -1px;\n  }\n  @media only screen and (min-width: 768px) {\n    .rr_countdown_wrapper {\n      padding-top: 8px;\n      padding-bottom: 8px;\n    }\n    .rr_countdown_container {\n      justify-content: center;\n      gap: 40px;\n      text-align: center;\n      padding: 0 15px;\n    }\n    .rr_countdown_text_content {\n      flex: 0 1 auto;\n    }\n    .rr_countdown_text_content h2 {\n      font-size: 24px;\n    }\n    .rr_countdown_text_content p {\n      font-size: 14px;\n      margin: 5px 0 0 0;\n    }\n    .rr_countdown_timer_box {\n      gap: 10px;\n    }\n    .rr_time_digit {\n      font-size: 24px;\n    }\n    .rr_timer_separator {\n      font-size: 24px;\n    }\n    .rr_time_label {\n      font-size: 12px;\n      margin-top: 2px;\n    }\n    .rr_timer_block {\n      min-width: 40px;\n    }\n  }\n</style>\n\n<div class=\"rr_countdown_wrapper\">\n  <div class=\"rr_countdown_container\">\n    <div class=\"rr_countdown_text_content\">\n      <h2>🌙 PROMOTION EID </h2>\n      <p>PRIX LE PLUS BAS DE L'ANNÉE</p>\n    </div>\n    <div class=\"rr_countdown_timer_box\" id=\"rr_timer_container_custom\">\n      <div class=\"rr_timer_block\">\n        <span class=\"rr_time_digit\" id=\"rr_hours_custom\">00</span>\n        <span class=\"rr_time_label\">Hrs</span>\n      </div>\n      <span class=\"rr_timer_separator\">:</span>\n      <div class=\"rr_timer_block\">\n        <span class=\"rr_time_digit\" id=\"rr_mins_custom\">00</span>\n        <span class=\"rr_time_label\">Mins</span>\n      </div>\n      <span class=\"rr_timer_separator\">:</span>\n      <div class=\"rr_timer_block\">\n        <span class=\"rr_time_digit\" id=\"rr_secs_custom\">00</span>\n        <span class=\"rr_time_label\">Secs</span>\n      </div>\n    </div>\n  </div>\n</div>\n\n<script>\n  (function() {\n    var countDownDate = new Date(\"2026-03-15T23:59:00\").getTime();\n\n    var elContainer = document.getElementById(\"rr_timer_container_custom\");\n    var elHours = document.getElementById(\"rr_hours_custom\");\n    var elMins = document.getElementById(\"rr_mins_custom\");\n    var elSecs = document.getElementById(\"rr_secs_custom\");\n\n    var timer = setInterval(function() {\n      var currentTime = new Date().getTime();\n      var distance = countDownDate - currentTime;\n\n      elContainer.classList.add(\"rr_timer_loaded\");\n\n      if (distance < 0) {\n        clearInterval(timer);\n        elHours.innerHTML = \"00\";\n        elMins.innerHTML = \"00\";\n        elSecs.innerHTML = \"00\";\n        return;\n      }\n\n      var totalHours = Math.floor(distance / 3600000);\n      var minutes = Math.floor((distance % 3600000) / 60000);\n      var seconds = Math.floor((distance % 60000) / 1000);\n\n      elHours.innerHTML = totalHours < 10 ? \"0\" + totalHours : totalHours;\n      elMins.innerHTML = minutes < 10 ? \"0\" + minutes : minutes;\n      elSecs.innerHTML = seconds < 10 ? \"0\" + seconds : seconds;\n    }, 1000);\n  })();\n</script>",
